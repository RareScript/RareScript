import typing;
import console;
import std;
import random;
import keyhook as key;

typing::array map := typing::array(typing::array, typing::array(typing::string, "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", " ", "█"), typing::array(typing::string, "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█", "█"));
typing::number i3 := 1;
typing::array maparr := typing::array(typing::void);
typing::array snake := typing::array(typing::array, typing::array(typing::number, 11, 10));
typing::bool eatenApple := false;
typing::number appleX := 0;
typing::number appleY := 0;
typing::string linemap(typing::array arr, typing::number i) {
  typing::string charmap(typing::string char, typing::number i2) {
    i3 := 1;
    while i3 <= snake->count {
      cond snake->@i3->1 = i2 and snake->@i3->2 = i {
        return "@";
      }
      i3 += 1;
    }
    cond appleX = i2 and appleY = i {
      return "+";
    }
    return char;
  }
  maparr := arr->map(charmap);
  return maparr->join("");
}
typing::void render() {
  typing::array map2 := map->map(linemap);
  typing::string rendered := map2->join("\n");
  console::clear();
  std::out(rendered);
}
typing::void checkApple() {
  cond eatenApple = false {
    snake->shift();
  }
  eatenApple := false;
  cond appleX = snake->-1->1 and appleY = snake->-1->2 {
    eatenApple := true;
    moveApple();
  }
}
typing::bool checkBounds(typing::number ox, typing::number oy) {
  typing::number x := snake->-1->1 + ox;
  typing::number y := snake->-1->2 + oy;
  cond map->@y->@x = "█" {
    return false;
  }
  i3 := 1;
  while i3 <= snake->count {
    cond snake->@i3->1 = x and snake->@i3->2 = y {
      return false;
    }
    i3 += 1;
  }
  return true;
}
typing::void up() {
  cond checkBounds(0, -1) {
    snake->addEnd(typing::array(typing::number, snake->-1->1, snake->-1->2 - 1));
    checkApple();
    render();
  }
}
typing::void left() {
  cond checkBounds(-1, 0) {
    snake->addEnd(typing::array(typing::number, snake->-1->1 - 1, snake->-1->2));
    checkApple();
    render();
  }
}
typing::void down() {
  cond checkBounds(0, 1) {
    snake->addEnd(typing::array(typing::number, snake->-1->1, snake->-1->2 + 1));
    checkApple();
    render();
  }
}
typing::void right() {
  cond checkBounds(1, 0) {
    snake->addEnd(typing::array(typing::number, snake->-1->1 + 1, snake->-1->2));
    checkApple();
    render();
  }
}
typing::void moveApple() {
  typing::bool cantPlace() {
    i3 := 1;
    while i3 <= snake->count {
      cond snake->@i3->1 = appleX and snake->@i3->2 = appleY {
        return true;
      }
      i3 += 1;
    }
    return false;
  }
  appleX := random::int(2, 21);
  appleY := random::int(2, 21);
  while cantPlace() {
    appleX := random::int(2, 21);
    appleY := random::int(2, 21);
  }
}
moveApple();
key::hook("w", up);
key::hook("a", left);
key::hook("s", down);
key::hook("d", right);
render();
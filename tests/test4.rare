import typing;
import console;

typing::number add60to(typing::number b) {
  return 60 + b;
}

typing::void out(typing::string *text) {
  console::out(text);
}

typing::function<typing::number, typing::number> getAdd() {
  return add60to;
}

typing::number getB(typing::boolean big) {
  cond big {
    return 100;
  } else {
    return 1;
  }
}

console::out(getAdd()(getB(false)));